{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "ignoreDeprecations": "6.0",

    "types": ["node", "jest"]
  },
  "include": ["src/**/*", "tests/**/*", "generated/**/*"],
  "exclude": ["node_modules", "dist"]
}